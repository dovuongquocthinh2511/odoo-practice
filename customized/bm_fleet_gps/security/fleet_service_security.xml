<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Using Custom BM Fleet GPS Groups with 2 permission levels -->
        <!-- 1. Người dùng (group_bm_fleet_user): See bookings they created, manage, or participate in -->
        <!-- 2. Sale Admin (group_bm_fleet_sale_admin): See bookings they dispatched + User permissions -->
        <!-- Odoo Base Admin (base.group_system) has full access automatically -->
        <!-- Note: group_bm_fleet_user implies fleet.fleet_group_user to prevent Access Rights warnings -->

        <!-- Record Rules for fleet.vehicle.log.services -->

        <!-- User can see bookings they created, manage, or participate in -->
        <record id="fleet_service_user_rule" model="ir.rule">
            <field name="name">BM Fleet Service: User Own and Managed Bookings</field>
            <field name="model_id" ref="fleet.model_fleet_vehicle_log_services"/>
            <field name="domain_force">['|', '|', '|', '|',
                ('create_uid', '=', user.id),
                ('submitted_by', '=', user.id),
                ('team_id.manager_id', '=', user.id),
                ('user_ids', 'in', [user.id]),
                ('manager_id', '=', user.id)
            ]</field>
            <field name="groups" eval="[(4, ref('group_bm_fleet_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Sale Admin can see ALL bookings for dispatch operations -->
        <record id="fleet_service_sale_admin_rule" model="ir.rule">
            <field name="name">BM Fleet Service: Sale Admin Full Access</field>
            <field name="model_id" ref="fleet.model_fleet_vehicle_log_services"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_bm_fleet_sale_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Record Rules for fleet.vehicle -->

        <!-- User can see vehicles in bookings they participate in -->
        <record id="fleet_vehicle_user_rule" model="ir.rule">
            <field name="name">BM Fleet Vehicle: User Own Bookings</field>
            <field name="model_id" ref="fleet.model_fleet_vehicle"/>
            <field name="domain_force">['|', '|', '|',
                ('log_services.create_uid', '=', user.id),
                ('log_services.submitted_by', '=', user.id),
                ('log_services.manager_id', '=', user.id),
                ('log_services.user_ids', 'in', [user.id])
            ]</field>
            <field name="groups" eval="[(4, ref('group_bm_fleet_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Sale Admin can see ALL vehicles for dispatch operations -->
        <record id="fleet_vehicle_sale_admin_rule" model="ir.rule">
            <field name="name">BM Fleet Vehicle: Sale Admin Full Access</field>
            <field name="model_id" ref="fleet.model_fleet_vehicle"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_bm_fleet_sale_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Record Rules for bm.fleet.transportation.journey -->

        <!-- User can see GPS journeys for vehicles in bookings they participate in -->
        <record id="fleet_journey_user_rule" model="ir.rule">
            <field name="name">BM Fleet Journey: User Own Vehicles</field>
            <field name="model_id" ref="model_bm_fleet_transportation_journey"/>
            <field name="domain_force">['|', '|', '|',
                ('vehicle_id.log_services.create_uid', '=', user.id),
                ('vehicle_id.log_services.submitted_by', '=', user.id),
                ('vehicle_id.log_services.manager_id', '=', user.id),
                ('vehicle_id.log_services.user_ids', 'in', [user.id])
            ]</field>
            <field name="groups" eval="[(4, ref('group_bm_fleet_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Sale Admin can see ALL GPS journeys for dispatch operations -->
        <record id="fleet_journey_sale_admin_rule" model="ir.rule">
            <field name="name">BM Fleet Journey: Sale Admin Full Access</field>
            <field name="model_id" ref="model_bm_fleet_transportation_journey"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_bm_fleet_sale_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
