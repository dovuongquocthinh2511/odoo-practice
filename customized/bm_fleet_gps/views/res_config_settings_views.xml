<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit General Settings to add Fleet GPS Configuration -->
        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.fleet.gps</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="90"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app string="Fleet GPS Tracking" name="bm_fleet_gps" groups="fleet.fleet_group_manager">

                        <!-- GPS API Configuration Section -->
                        <block title="GPS API Configuration" name="gps_api_config">
                            <setting string="ADSUN GPS API" help="Configure connection to ADSUN GPS tracking platform">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="gps_api_url" class="col-lg-3 o_light_label" string="API URL"/>
                                        <field name="gps_api_url" placeholder="https://systemroute.adsun.vn/api"/>
                                    </div>
                                    <div class="row">
                                        <label for="gps_api_username" class="col-lg-3 o_light_label" string="Username"/>
                                        <field name="gps_api_username" placeholder="API Username"/>
                                    </div>
                                    <div class="row">
                                        <label for="gps_api_password" class="col-lg-3 o_light_label" string="Password"/>
                                        <field name="gps_api_password" password="True" placeholder="API Password"/>
                                    </div>
                                    <div class="row">
                                        <label for="gps_default_company_id" class="col-lg-3 o_light_label" string="Company ID"/>
                                        <field name="gps_default_company_id" placeholder="1136"/>
                                    </div>
                                    <div class="row">
                                        <label for="gps_ssl_verify" class="col-lg-3 o_light_label" string="SSL Verification"/>
                                        <field name="gps_ssl_verify"/>
                                    </div>
                                </div>
                            </setting>
                        </block>

                        <!-- Traffic Violation Check Configuration -->
                        <block title="Traffic Violation Checking" name="violation_check_config">
                            <setting string="Enable Violation Checking"
                                     help="Automatically check traffic violations via iphatnguoi.com API when license plate is entered">
                                <field name="violation_check_enabled"/>
                            </setting>

                            <setting string="Violation API Configuration"
                                     help="Configure violation checking API settings"
                                     invisible="not violation_check_enabled">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="violation_api_url" class="col-lg-3 o_light_label" string="API URL"/>
                                        <field name="violation_api_url"
                                               placeholder="https://iphatnguoi.com/api/check-violation"
                                               required="violation_check_enabled"/>
                                    </div>
                                    <div class="row">
                                        <label for="violation_cache_hours" class="col-lg-3 o_light_label" string="Cache Duration (hours)"/>
                                        <field name="violation_cache_hours"
                                               class="oe_inline"
                                               required="violation_check_enabled"/>
                                        <span class="o_form_label ms-2">hours</span>
                                    </div>
                                    <div class="text-muted">
                                        <i class="fa fa-info-circle"/>
                                        Violation data will be cached for the specified duration to reduce API calls.
                                        Set to 0 to disable caching (not recommended).
                                    </div>
                                </div>
                            </setting>
                        </block>

                        <!-- Data Management Section -->
                        <block title="Data Management" name="data_management">
                            <setting string="Journey Data Retention"
                                     help="Automatically delete old GPS journey data to optimize database performance">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="gps_retention_days" class="col-lg-3 o_light_label" string="Keep Data For"/>
                                        <field name="gps_retention_days" class="oe_inline"/>
                                        <span class="o_form_label ms-2">days</span>
                                    </div>
                                </div>
                            </setting>

                            <setting string="Batch Processing"
                                     help="Configure batch sizes for better performance during sync and cleanup">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="gps_sync_batch_size" class="col-lg-3 o_light_label" string="Sync Batch Size"/>
                                        <field name="gps_sync_batch_size" class="oe_inline"/>
                                        <span class="o_form_label ms-2">vehicles per batch</span>
                                    </div>
                                    <div class="row">
                                        <label for="gps_delete_batch_size" class="col-lg-3 o_light_label" string="Delete Batch Size"/>
                                        <field name="gps_delete_batch_size" class="oe_inline"/>
                                        <span class="o_form_label ms-2">records per batch</span>
                                    </div>
                                    <div class="row">
                                        <label for="geocoding_batch_limit" class="col-lg-3 o_light_label" string="Geocoding Batch"/>
                                        <field name="geocoding_batch_limit" class="oe_inline"/>
                                        <span class="o_form_label ms-2">addresses per run</span>
                                    </div>
                                </div>
                            </setting>
                        </block>

                    </app>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
