<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Override action to set Kanban as default view -->
    <record id="fleet.fleet_vehicle_log_services_action" model="ir.actions.act_window">
        <field name="view_mode">kanban,list,form,graph,pivot,activity</field>
        <field name="context">{'search_default_active_services': 1}</field>
    </record>

    <!-- Action for User: Booking Request with Wizard Button -->
    <record id="fleet_vehicle_services_user_action" model="ir.actions.act_window">
        <field name="name">Booking</field>
        <field name="res_model">fleet.vehicle.log.services</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[]</field>
        <field name="context">{
            'search_default_active_services': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register new vehicle booking
            </p>
            <p>
                Click "Vehicle Booking Registration" button to create new request
            </p>
        </field>
    </record>

    <!-- Fleet Vehicle Log Services Kanban View for Users with Custom Create Button -->
    <record id="view_fleet_vehicle_log_services_kanban_user" model="ir.ui.view">
        <field name="name">fleet.vehicle.log.services.kanban.user</field>
        <field name="model">fleet.vehicle.log.services</field>
        <field name="priority">15</field>
        <field name="groups_id" eval="[(4, ref('bm_fleet_gps.group_bm_fleet_user'))]"/>
        <field name="arch" type="xml">
            <kanban default_group_by="state" quick_create="false" class="o_kanban_small_column"
                    create="true" string="Vehicle Booking Registration" on_create="bm_fleet_gps.action_fleet_service_booking_wizard_menu"
                    records_draggable="false">
                <field name="name"/>
                <field name="service_category"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="date"/>
                <field name="state" readonly="1"/>
                <field name="activity_ids"/>
                <field name="activity_state"/>
                <field name="work_location"/>
                <field name="submitted_by"/>
                <progressbar field="activity_state" colors='{"planned": "success", "today": "warning", "overdue": "danger"}'/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <div class="o_kanban_record_subtitle">
                                        <field name="service_category"/>
                                    </div>
                                    <div class="o_kanban_record_subtitle text-muted" t-if="record.submitted_by.raw_value">
                                        <i class="fa fa-user-circle-o"/> <field name="submitted_by"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div class="row">
                                    <div class="col-12">
                                        <i class="fa fa-car"/> <field name="vehicle_id"/>
                                    </div>
                                    <div class="col-12" t-if="record.driver_id.raw_value">
                                        <i class="fa fa-user"/> <field name="driver_id"/>
                                    </div>
                                    <div class="col-12">
                                        <i class="fa fa-calendar"/> <field name="date"/>
                                    </div>
                                    <div class="col-12" t-if="record.work_location.raw_value">
                                        <i class="fa fa-briefcase"/> <field name="work_location"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="activity_ids" widget="kanban_activity"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="state" widget="label_selection"
                                           options="{'classes': {'new': 'secondary', 'pending_manager': 'info', 'pending_dispatch': 'warning', 'running': 'primary', 'done': 'success', 'cancelled': 'danger'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

