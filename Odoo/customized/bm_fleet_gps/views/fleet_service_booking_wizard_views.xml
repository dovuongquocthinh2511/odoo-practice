<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wizard Form View -->
    <record id="view_fleet_service_booking_wizard_form" model="ir.ui.view">
        <field name="name">bm.fleet.service.booking.wizard.form</field>
        <field name="model">bm.fleet.service.booking.wizard</field>
        <field name="arch" type="xml">
            <form string="Vehicle Booking Registration" create="false">
                <field name="service_category" invisible="1"/>
                <group string="Work Information">
                    <group>
                        <field name="work_departure_location" widget="address_autocomplete" placeholder="Enter departure address (at least 3 characters)..."/>
                        <field name="work_location" widget="address_autocomplete" placeholder="Enter destination address (at least 3 characters)..."/>
                        <field name="work_purpose" widget="text"/>
                        <field name="work_date_start" widget="datetime"/>
                        <field name="work_date_end" widget="datetime"/>
                    </group>
                    <group>
                        <field name="team_id" options="{'no_create': True}" placeholder="Select team or contact Admin to create new team"/>
                        <field name="requester_id" options="{'no_create': True}"/>
                        <field name="user_ids" widget="many2many_tags" placeholder="Select accompanying members (if any)"/>
                        <field name="manager_id" groups="base.group_system"/>
                    </group>
                </group>

                <footer>
                    <button string="Register" name="action_create_booking" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open wizard -->
    <record id="action_fleet_service_booking_wizard" model="ir.actions.act_window">
        <field name="name">Vehicle Booking Registration</field>
        <field name="res_model">bm.fleet.service.booking.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_fleet_service_booking_wizard_form"/>
    </record>

</odoo>
