#. module: bm_fleet_gps
#: model:res.groups,comment:bm_fleet_gps.group_bm_fleet_user
msgid ""
"\n"
"                Người dùng có quyền:\n"
"                - Tạo đơn đặt xe mới\n"
"                - Xem đơn đặt xe của bản thân (created, assigned, hoặc managed)\n"
"                - Chỉnh sửa đơn đặt xe liên quan\n"
"                - Phê duyệt đơn đặt xe khi là manager\n"
"                - Reset đơn đặt xe bị hủy\n"
"                - Chỉ truy cập menu Đặt xe (KHÔNG thấy menu Vehicles)\n"
"\n"
"                Note: KHÔNG include fleet.fleet_group_user để ẩn menu Vehicles\n"
"                      Quyền truy cập fleet.vehicle và fleet.vehicle.log.services\n"
"                      được cấp trực tiếp qua ir.model.access.csv và record rules\n"
"                      Menu Vehicles bị ẩn qua override trong views/menus.xml\n"
"            "
msgstr ""

#. module: bm_fleet_gps
#: model:res.groups,comment:bm_fleet_gps.group_bm_fleet_sale_admin
msgid ""
"\n"
"                Sale Admin có quyền:\n"
"                - Tất cả quyền của Người dùng\n"
"                - Xem đơn đặt xe đã dispatch bởi họ\n"
"                - Điều xe (phân công xe và tài xế)\n"
"                - Từ chối điều xe\n"
"                - Hoàn thành đơn đặt xe\n"
"                - Chỉnh sửa thông tin điều xe\n"
"                - KHÔNG có quyền phê duyệt Manager\n"
"                - KHÔNG có quyền xóa đơn đặt xe\n"
"            "
msgstr ""

